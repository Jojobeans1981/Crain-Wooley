generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Lead {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  firstName       String
  lastName        String
  email           String        @unique
  phone           String

  practiceArea    PracticeArea
  caseType        String
  description     String
  urgency         Urgency
  qualified       Boolean       @default(false)
  disqualifyReason String?

  // ── Full estate intake (Wills & Trust / Probate questionnaire) ──
  // All nullable + additive so the migration is safe on existing rows.
  intakeType        IntakeType?
  zip               String?
  dob               String?
  source            String?
  notes             String?
  preferredOffice   String?
  consultationFormat String?
  preferredContactTime String?
  clientLivesInTexas Boolean?
  // Family
  maritalStatus     String?
  hasChildren       Boolean?
  childrenCount     String?
  hasMinorChildren  Boolean?
  hasSpecialNeedsDependent Boolean?
  spouseName        String?
  spouseDob         String?
  spouseEmail       String?
  spousePhone       String?
  dateOfMarriage    String?
  spouseChildrenSeparate String?
  // Estate
  assetRange        String?
  debtRange         String?
  ownsRealEstate    Boolean?
  realEstateCount   String?
  ownsBusiness      Boolean?
  businessType      String?
  businessHasSuccession Boolean?
  hasExistingPlan   Boolean?
  existingPlanYear  String?
  deedAddresses     String?
  companyInfo       String?
  ownsOutOfState    Boolean?
  // Wishes / additional
  topConcerns       String?
  worstCaseFear     String?
  specialGifts      String?
  remoteContingentBeneficiaries String?
  organDonationNotes String?
  livingWillYou     Boolean?
  livingWillSpouse  Boolean?
  receivesGovBenefits Boolean?
  hasDivorcePayments Boolean?
  hasMarriageContract Boolean?
  hasFiledGiftTaxReturns Boolean?
  hasPriorEstatePlan Boolean?
  childrenHaveSpecialNeedsExtended Boolean?
  childrenReceiveGovBenefits Boolean?
  supportsAdultDependents Boolean?
  // Services chosen (comma-joined for quick filtering)
  services          String?
  // Probate
  decedentName      String?
  decedentDateOfDeath String?
  decedentRelationship String?
  decedentRelationshipOther String?
  decedentCounty    String?
  decedentTexasResident Boolean?
  decedentHadTrust  Boolean?
  willExists        String?
  willHasOriginal   String?
  willYear          String?
  probateCourtFiled String?
  probateCountyFiled String?
  probateExecutorAppointed Boolean?
  heirDisputes      String?
  // Repeating groups stored as JSON (sqlite TEXT)
  childrenDetails       Json?
  realEstateProperties  Json?
  primaryBeneficiaries  Json?
  fiduciaries           Json?
  attachments           Json?

  status          LeadStatus    @default(NEW)

  paymentStatus   PaymentStatus @default(UNPAID)
  stripeSessionId String?
  paidAt          DateTime?

  consultAt       DateTime?
  calEventId      String?

  sequences       Sequence[]
  auditEvents     AuditEvent[]
  hired           Boolean       @default(false)
  hiredAt         DateTime?
  nurturePaused   Boolean       @default(false)

  clioContactId   String?
  clioMatterId    String?
  clioSyncedAt    DateTime?
  clioJobs        ClioSyncJob[]

  optedOut        Boolean   @default(false)
  optedOutAt      DateTime?

  @@index([status])
  @@index([email])
  @@index([phone])
}

model Sequence {
  id                 String          @id @default(cuid())
  leadId             String
  lead               Lead            @relation(fields: [leadId], references: [id])
  channel            Channel
  step               Int
  scheduledAt        DateTime
  sentAt             DateTime?
  status             SequenceStatus  @default(PENDING)
  template           String
  attempts           Int             @default(0)
  lastError          String?
  lockedAt           DateTime?
  externalId         String?         @unique // Idempotency key for SMS/email providers
  consecutiveFailures Int            @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([leadId])
  @@index([scheduledAt])
  @@index([status])
}

model AuditEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])

  type      String
  actor     String?
  ip        String?
  userAgent String?
  meta      Json?

  @@index([leadId])
  @@index([type])
  @@index([createdAt])
}

enum PracticeArea {
  ESTATE_PLANNING
  PROBATE
  FAMILY_LAW
  PERSONAL_INJURY
  BUSINESS_LAW
  CRIMINAL_DEFENSE
  REAL_ESTATE
  OTHER
}

enum IntakeType {
  WILLS
  PROBATE
}

enum Urgency {
  IMMEDIATE
  WITHIN_WEEK
  WITHIN_MONTH
  RESEARCHING
}

enum LeadStatus {
  NEW
  QUALIFIED
  DISQUALIFIED
  PAYMENT_PENDING
  PAYMENT_COMPLETE
  SCHEDULED
  CONSULTED
  HIRED
  CLOSED_LOST
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  REFUNDED
}

enum Channel {
  SMS
  EMAIL
}

enum SequenceStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
  SKIPPED
}

model NurtureTemplate {
  id        String   @id @default(cuid())
  day       Int
  channel   Channel
  subject   String?
  body      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([day])
  @@index([channel])
}

model OnboardingTaskTemplate {
  id             String   @id @default(cuid())
  name           String
  dueOffsetHours Int      @default(24)
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([active])
  @@index([sortOrder])
}

model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  role      AdminRole @default(VIEWER)
  createdAt DateTime  @default(now())
}

model ClioToken {
  id           String   @id @default("singleton")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Disconnect-safe Clio sync outbox. Work is persisted here when Clio may be
/// offline and drained idempotently when it is connected. idempotencyKey is
/// `${leadId}:${type}` so the same lead+type is never double-queued.
model ClioSyncJob {
  id             String         @id @default(cuid())
  type           ClioSyncType
  leadId         String
  lead           Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  idempotencyKey String         @unique
  status         ClioSyncStatus @default(PENDING)
  attempts       Int            @default(0)
  lastError      String?
  nextAttemptAt  DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status, nextAttemptAt])
  @@index([leadId])
}

enum ClioSyncType {
  UPSERT_CONTACT
  ONBOARD_MATTER
}

enum ClioSyncStatus {
  PENDING
  IN_PROGRESS
  DONE
  FAILED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}
