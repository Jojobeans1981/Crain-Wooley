generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Lead {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  firstName       String
  lastName        String
  email           String        @unique
  phone           String

  practiceArea    PracticeArea
  caseType        String
  description     String
  urgency         Urgency
  qualified       Boolean       @default(false)
  disqualifyReason String?

  status          LeadStatus    @default(NEW)

  paymentStatus   PaymentStatus @default(UNPAID)
  stripeSessionId String?
  paidAt          DateTime?

  consultAt       DateTime?
  calEventId      String?

  sequences       Sequence[]
  auditEvents     AuditEvent[]
  hired           Boolean       @default(false)
  hiredAt         DateTime?
  nurturePaused   Boolean       @default(false)

  clioContactId   String?
  clioMatterId    String?

  optedOut        Boolean   @default(false)
  optedOutAt      DateTime?

  @@index([status])
  @@index([email])
  @@index([phone])
}

model Sequence {
  id                 String          @id @default(cuid())
  leadId             String
  lead               Lead            @relation(fields: [leadId], references: [id])
  channel            Channel
  step               Int
  scheduledAt        DateTime
  sentAt             DateTime?
  status             SequenceStatus  @default(PENDING)
  template           String
  attempts           Int             @default(0)
  lastError          String?
  lockedAt           DateTime?
  externalId         String?         @unique // Idempotency key for SMS/email providers
  consecutiveFailures Int            @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([leadId])
  @@index([scheduledAt])
  @@index([status])
}

model AuditEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])

  type      String
  actor     String?
  ip        String?
  userAgent String?
  meta      Json?

  @@index([leadId])
  @@index([type])
  @@index([createdAt])
}

enum PracticeArea {
  ESTATE_PLANNING
  FAMILY_LAW
  PERSONAL_INJURY
  BUSINESS_LAW
  CRIMINAL_DEFENSE
  REAL_ESTATE
  OTHER
}

enum Urgency {
  IMMEDIATE
  WITHIN_WEEK
  WITHIN_MONTH
  RESEARCHING
}

enum LeadStatus {
  NEW
  QUALIFIED
  DISQUALIFIED
  PAYMENT_PENDING
  PAYMENT_COMPLETE
  SCHEDULED
  CONSULTED
  HIRED
  CLOSED_LOST
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  REFUNDED
}

enum Channel {
  SMS
  EMAIL
}

enum SequenceStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
  SKIPPED
}

model NurtureTemplate {
  id        String   @id @default(cuid())
  day       Int
  channel   Channel
  subject   String?
  body      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([day])
  @@index([channel])
}

model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  role      AdminRole @default(VIEWER)
  createdAt DateTime  @default(now())
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}
