# Database — Postgres (Supabase). Required in Vercel for runtime + migrations.
# DATABASE_URL: pooled connection (Supabase "Transaction" pooler, port 6543) —
#   used by the app at runtime via the PrismaPg adapter. Add ?pgbouncer=true.
# DIRECT_URL:   direct connection (port 5432) — used by `prisma migrate` only.
# Both are on the Supabase project Settings → Database → Connection string.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Supabase (Admin Auth)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Seed (Admin Auth)
SEED_ADMIN_EMAIL="admin@example.com"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Twilio (SMS)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_FROM_NUMBER="+1..."

# Resend (Email)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="intake@crainwooley.com"

# Cal.com
NEXT_PUBLIC_CAL_LINK="crainwooley/consultation"

# App
NEXTAUTH_SECRET="your-secret-here"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Clio (stubbed - fill in when credentials arrive)
CLIO_CLIENT_ID=""
CLIO_CLIENT_SECRET=""
CLIO_ACCESS_TOKEN=""

# Demo Mode (Set to 'true' for shareable presentation mode)
NEXT_PUBLIC_DEMO_MODE="false"
